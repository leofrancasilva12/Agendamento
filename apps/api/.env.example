DATABASE_URL="postgresql://agendamento:agendamento@localhost:5432/agendamento?schema=public"
# Usada pelo Prisma para rodar migrations. Em Postgres "normal" (Docker,
# Railway, Render) é igual à DATABASE_URL. No Supabase, DATABASE_URL deve
# apontar para o Connection Pooler (porta 6543, com ?pgbouncer=true) e
# DIRECT_URL para a Direct Connection (porta 5432) — ver README.
DIRECT_URL="postgresql://agendamento:agendamento@localhost:5432/agendamento?schema=public"
JWT_SECRET="troque-por-um-segredo-forte"
PORT=3333
WEB_ORIGIN="http://localhost:3000"

# SMTP (e-mail transacional) — se vazio, e-mails são apenas logados
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="no-reply@seudominio.com.br"

# Webhooks n8n (WhatsApp) — se vazios, envio é apenas logado
N8N_BOOKING_CREATED_WEBHOOK_URL=
N8N_BOOKING_REMINDER_WEBHOOK_URL=
